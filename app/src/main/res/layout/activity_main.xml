<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
     >

    <Space
        android:layout_width="match_parent"
        android:layout_height="50dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/lblMessage1"
        android:text="Welcome to My App" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="50dp" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnOpenCalc"
        android:text="Open Calculator"
        android:onClick="handleOpenCalc"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnOpenWeb"
        android:text="Open Website"
        android:onClick="handleOpenWebsite"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnShowChats"
        android:text="Show Chats Screen"
        android:onClick="handleOpenChatsScreen"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnShowMessage1"
        android:text="Show a Message"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoCheckbox"
        android:text="Checkbox"
        android:onClick="handleOpenCheckbox"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoCheckbox2"
        android:text="Checkbox v2"
        android:onClick="handleOpenCheckbox2"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoRadiobutton"
        android:text="Radio Button"
        android:onClick="handleOpenDemoRadio"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoSpinner"
        android:text="Spinner Demo"
        android:onClick="handleOpenSpinner"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoImageView"
        android:text="ImageView Demo"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoDateTimePickers"
        android:text="Date/Time Picker Demo"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDemoRawFiles"
        android:text="Packaged Files Demo"
        />

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/btnDBExample1"
        android:text="Db Demo 1"
        />
</LinearLayout>

</ScrollView>